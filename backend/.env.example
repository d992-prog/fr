DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/frdrop
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
SESSION_SECRET_KEY=change-me-session-secret
SESSION_COOKIE_SECURE=false
OWNER_LOGIN=france_admin
OWNER_PASSWORD=change-me-owner-password
RDAP_BASE_URL=https://rdap.nic.fr/domain/
DNS_TIMEOUT_SECONDS=2.5
DNS_FALLBACK_NAMESERVERS=1.1.1.1,8.8.8.8
RDAP_TIMEOUT_SECONDS=4.0
WORKER_CYCLE_TIMEOUT_SECONDS=10.0
WORKER_SUPERVISOR_INTERVAL_SECONDS=15
WORKER_STALL_THRESHOLD_SECONDS=45
MAX_PROXY_ATTEMPTS_PER_CYCLE=3
NORMAL_CHECK_INTERVAL=1.5
BURST_CHECK_INTERVAL=0.35
PATTERN_WINDOW_START_MINUTE=31
PATTERN_WINDOW_END_MINUTE=34
PATTERN_SLOW_INTERVAL=60.0
PATTERN_FAST_INTERVAL=0.5
AVAILABLE_RECHECK_INTERVAL=1800.0
AVAILABLE_CAPTURE_WATCH_SECONDS=15
AVAILABLE_CAPTURE_WATCH_INTERVAL=0.5
AVAILABLE_CONFIRMATION_THRESHOLD=3
PROXY_FAIL_THRESHOLD=3
DEAD_PROXY_RETRY_SECONDS=300
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
CORS_ORIGINS=*
